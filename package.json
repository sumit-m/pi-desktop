{
  "name": "pi-desktop",
  "version": "0.0.7-alpha",
  "description": "Desktop GUI frontend for the Pi coding agent",
  "main": "out/main/index.js",
  "author": "Pi Desktop GUI Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/FaqFirebase/pi-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/FaqFirebase/pi-desktop"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "ai",
    "electron",
    "desktop",
    "ide"
  ],
  "bin": {
    "pi-desktop": "./bin/pi-desktop.js"
  },
  "scripts": {
    "dev": "electron-vite build && electron-vite preview -- --no-sandbox",
    "dev:hot": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src bin scripts",
    "package": "electron-vite build && electron-builder",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:linux:appimage": "electron-vite build && electron-builder --linux AppImage",
    "package:linux:all": "electron-vite build && electron-builder --linux",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:mac:dmg": "electron-vite build && electron-builder --mac dmg",
    "package:mac:zip": "electron-vite build && electron-builder --mac zip",
    "package:win": "electron-vite build && electron-builder --win",
    "package:win:nsis": "electron-vite build && electron-builder --win nsis",
    "package:win:portable": "electron-vite build && electron-builder --win portable",
    "package:all": "electron-vite build && electron-builder --linux --mac --win",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@lezer/highlight": "^1.2.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.511.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^41.7.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "dev.pi.desktop-gui",
    "productName": "Pi Desktop",
    "copyright": "Copyright 2026 Pi Desktop GUI Contributors. Licensed under the Apache License, Version 2.0.",
    "files": [
      "out/**/*",
      "bin/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "resources/icons",
      "synopsis": "Desktop GUI for the Pi coding agent",
      "description": "An Electron desktop application that provides a GUI frontend for the Pi coding agent.",
      "maintainer": "Pi Desktop GUI Contributors",
      "artifactName": "Pi-Desktop-${version}-${os}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icons/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "Pi-Desktop-${version}-${os}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icons/icon.ico",
      "artifactName": "Pi-Desktop-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pi Desktop",
      "installerIcon": "resources/icons/icon.ico",
      "uninstallerIcon": "resources/icons/icon.ico",
      "artifactName": "Pi-Desktop-${version}-${os}-${arch}-setup.${ext}"
    },
    "appImage": {
      "license": "LICENSE"
    }
  }
}
